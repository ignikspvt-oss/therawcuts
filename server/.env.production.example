# ==========================================
# THE RAW CUTS - PRODUCTION ENV (SERVER)
# ==========================================
# Copy to .env and fill in real values for production.
# NEVER commit .env to version control.

NODE_ENV=production
PORT=5000

# MongoDB (use connection string from MongoDB Atlas or provider)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/therawcuts

# JWT secrets — generate strong random values:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<64+ char random hex string>
JWT_REFRESH_SECRET=<different 64+ char random hex string>

# CSRF secret — generate with same command as above
CSRF_SECRET=<64+ char random hex string>

# Client URL (exact domain, no trailing slash)
CLIENT_URL=https://therawcuts.com

# Razorpay LIVE credentials
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=<live razorpay secret>

# Resend API key for transactional emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_SENDER=The Raw Cuts <hello@therawcuts.com>

# Initial admin credentials (change immediately after first login)
ADMIN_EMAIL=admin@therawcuts.com
ADMIN_PASSWORD=<strong 16+ character password>
